# Anthropic API key (verplicht)
ANTHROPIC_API_KEY=sk-ant-...

# Beveilig de agent-endpoints met een Bearer token (aanbevolen voor productie)
# Laat leeg om de endpoints open te laten (alleen lokaal/testen)
AGENT_API_KEY=

# CMS API-key
WEBFLOW_API_KEY=...
WEBFLOW_COLLECTION_ID=       # ID van de pagina-collectie (te vinden in Webflow dashboard > CMS)